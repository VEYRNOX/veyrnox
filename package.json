    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-toggle": "^1.1.12",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@reown/walletkit": "^1.5.5",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^1.6.0",
    "@scure/btc-signer": "^2.2.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.2",
    "@trezor/connect-web": "^9.7.3",
    "@walletconnect/core": "2.23.10",
    "@walletconnect/utils": "^2.23.10",
    "buffer": "^6.0.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.5.2",
    "ethers": "^6.17.0",
