{
  "name": "veyrnox-wallet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/bundle-trezor-connect.mjs",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "lint:rings": "eslint src --quiet",
    "typecheck": "tsc -p ./jsconfig.json",
    "typecheck:core": "tsc -p ./jsconfig.wallet-core.json",
    "preview": "vite preview",
    "icons:ios": "node scripts/generate-ios-icons.mjs",
    "check:rng": "node scripts/check-crypto-rng.mjs",
    "check:strays": "node scripts/check-stray-files.mjs",
    "hooks:install": "node scripts/setup-hooks.mjs",
    "check:deniability-strings": "node scripts/check-deniability-strings.mjs",
    "check:log-redaction": "node scripts/check-log-redaction-patch.mjs",
    "check:release-hygiene": "node scripts/check-release-hygiene.mjs",
    "check:finding-ids": "node scripts/check-finding-id-consistency.mjs",
    "check:cert-pin-manager": "node scripts/check-cert-pin-manager-safety.mjs",
    "check:rasp-bypass": "node scripts/check-rasp-bypass.mjs",
    "check:iap-preflight": "node scripts/preflight-iap-config.mjs",
    "verify:onchain": "node scripts/verify-onchain-evidence.mjs",
    "phase2:checklist": "node scripts/phase2-checklist-runner.mjs",
    "phase2:checklist:quick": "node scripts/phase2-checklist-runner.mjs --no-tests --no-native",
    "pretest": "node scripts/check-crypto-rng.mjs && node scripts/check-deniability-strings.mjs && node scripts/check-finding-id-consistency.mjs && node scripts/check-cert-pin-manager-safety.mjs && npm run typecheck:core",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "android:test": "wdio tests/android/wdio.conf.js",
    "ios:test": "wdio tests/ios/wdio.conf.js",
    "ios:test:vault": "wdio tests/ios/wdio.conf.js --spec tests/ios/specs/vault.spec.js",
    "ios:test:send": "wdio tests/ios/wdio.conf.js --spec tests/ios/specs/send.spec.js",
    "ios:test:hardware-kek": "wdio tests/ios/wdio.conf.js --spec tests/ios/specs/hardware-kek-e2e.spec.js",
    "ios:test:biometric-reenroll": "wdio tests/ios/wdio.conf.js --spec tests/ios/specs/biometric-reenroll-e2e.spec.js",
    "android:test:vault": "wdio tests/android/wdio.conf.js --spec tests/android/specs/vault.spec.js",
    "android:test:send": "wdio tests/android/wdio.conf.js --spec tests/android/specs/send.spec.js",
    "android:test:frida": "wdio tests/android/wdio.conf.js --spec tests/android/specs/frida-hook-detection-e2e.spec.js",
    "android:test:send-scenarios": "wdio tests/android/wdio.conf.js --spec tests/android/specs/send-scenarios-e2e.spec.js",
    "android:test:hardware-kek": "wdio tests/android/wdio.conf.js --spec tests/android/specs/hardware-kek-e2e.spec.js",
    "android:test:biometric-unlock": "wdio tests/android/wdio.conf.js --spec tests/android/specs/biometric-unlock-e2e.spec.js",
    "android:test:hidden-wallet": "wdio tests/android/wdio.conf.js --spec tests/android/specs/hidden-wallet-e2e.spec.js",
    "android:test:panic-pin": "wdio tests/android/wdio.conf.js --spec tests/android/specs/panic-pin-e2e.spec.js",
    "android:test:backup": "wdio tests/android/wdio.conf.js --spec tests/android/specs/backup-restore-e2e.spec.js",
    "android:test:dapp-alerts": "wdio tests/android/wdio.conf.js --spec tests/android/specs/dapp-security-alerts-e2e.spec.js",
    "android:test:kdf-perf": "wdio tests/android/wdio.conf.js --spec tests/android/specs/kdf-performance-e2e.spec.js",
    "android:test:passkey-clone": "wdio tests/android/wdio.conf.js --spec tests/android/specs/passkey-clone-detection-e2e.spec.js",
    "android:test:fee-analytics": "wdio tests/android/wdio.conf.js --spec tests/android/specs/fee-analytics-networth-e2e.spec.js",
    "android:test:log1": "wdio tests/android/wdio.conf.js --spec tests/android/specs/log1-bridge-redaction-e2e.spec.js",
    "android:test:flag-secure": "wdio tests/android/wdio.conf.js --spec tests/android/specs/flag-secure-screenshot-e2e.spec.js",
    "android:test:new-suites": "wdio tests/android/wdio.conf.js --spec tests/android/specs/backup-restore-e2e.spec.js --spec tests/android/specs/dapp-security-alerts-e2e.spec.js --spec tests/android/specs/kdf-performance-e2e.spec.js --spec tests/android/specs/passkey-clone-detection-e2e.spec.js --spec tests/android/specs/fee-analytics-networth-e2e.spec.js --spec tests/android/specs/log1-bridge-redaction-e2e.spec.js",
    "analyze:build": "npm run build -- --mode analyze",
    "analyze:deps": "npm ls --depth=0",
    "cap:sync": "cap sync && node scripts/register-local-ios-plugins.mjs",
    "preios": "node scripts/gen-ios-icon.mjs",
    "ios": "cap sync ios && node scripts/register-local-ios-plugins.mjs && cap open ios",
    "mobile:build": "npm run build && npm run cap:sync",
    "mobile:build:demo": "cross-env VITE_DEMO_MODE=1 npm run build && npm run cap:sync",
    "build:demo": "cross-env VITE_DEMO_MODE=1 npm run build",
    "build:release": "cross-env VITE_RELEASE=1 npm run build",
    "mobile:build:release": "cross-env VITE_RELEASE=1 npm run build && npm run cap:sync",
    "build:beta": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=\"Testnet Beta\" npm run build",
    "mobile:build:beta": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=\"Testnet Beta\" npm run build && npm run cap:sync",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:run": "npm run build && cap run android",
    "build:sit": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=SIT npm run build",
    "build:uat": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=UAT npm run build",
    "mobile:build:sit": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=SIT npm run build && npm run cap:sync",
    "mobile:build:uat": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=UAT npm run build && npm run cap:sync",
    "postinstall": "patch-package"
  },
