{
  "name": "veyrnox-wallet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/bundle-trezor-connect.mjs",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vite build",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p ./jsconfig.json",
    "typecheck:core": "tsc -p ./jsconfig.wallet-core.json",
    "preview": "vite preview",
    "check:rng": "node scripts/check-crypto-rng.mjs",
    "pretest": "node scripts/check-crypto-rng.mjs && npm run typecheck:core",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "android:test": "wdio tests/android/wdio.conf.js",
    "android:test:vault": "wdio tests/android/wdio.conf.js --spec tests/android/specs/vault.spec.js",
    "android:test:send": "wdio tests/android/wdio.conf.js --spec tests/android/specs/send.spec.js",
    "android:test:send-scenarios": "wdio tests/android/wdio.conf.js --spec tests/android/specs/send-scenarios-e2e.spec.js",
    "android:test:hardware-kek": "wdio tests/android/wdio.conf.js --spec tests/android/specs/hardware-kek-e2e.spec.js",
    "android:test:biometric-unlock": "wdio tests/android/wdio.conf.js --spec tests/android/specs/biometric-unlock-e2e.spec.js",
    "android:test:hidden-wallet": "wdio tests/android/wdio.conf.js --spec tests/android/specs/hidden-wallet-e2e.spec.js",
    "android:test:panic-pin": "wdio tests/android/wdio.conf.js --spec tests/android/specs/panic-pin-e2e.spec.js",
    "analyze:build": "npm run build -- --mode analyze",
    "analyze:deps": "npm ls --depth=0",
    "cap:sync": "cap sync && node scripts/register-local-ios-plugins.mjs",
    "preios": "node scripts/gen-ios-icon.mjs",
    "ios": "cap sync ios && node scripts/register-local-ios-plugins.mjs && cap open ios",
    "mobile:build": "npm run build && npm run cap:sync",
    "mobile:build:demo": "cross-env VITE_DEMO_MODE=1 npm run build && npm run cap:sync",
    "build:demo": "cross-env VITE_DEMO_MODE=1 npm run build",
    "build:release": "cross-env VITE_RELEASE=1 npm run build",
    "mobile:build:release": "cross-env VITE_RELEASE=1 npm run build && npm run cap:sync",
    "build:beta": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=\"Testnet Beta\" npm run build",
    "mobile:build:beta": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=\"Testnet Beta\" npm run build && npm run cap:sync",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:run": "npm run build && cap run android",
    "build:sit": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=SIT npm run build",
    "build:uat": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=UAT npm run build",
    "mobile:build:sit": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=SIT npm run build && npm run cap:sync",
    "mobile:build:uat": "cross-env VITE_RELEASE=1 VITE_ENV_LABEL=UAT npm run build && npm run cap:sync",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor-community/speech-recognition": "^7.0.1",
