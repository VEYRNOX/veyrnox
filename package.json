    "webdriverio": "^9.29.1"
  },
  "//overrides-audit-notes": [
    "serialize-javascript: HIGH (GHSA RCE via RegExp.flags) — forced to ^7.0.0 via override; only affects @wdio/mocha-framework (devDep test runner, not production wallet code). Fixed 2026-07-05.",
    "elliptic: LOW — forced to ^6.6.1; mitigates transitive ECDSA risky-primitive advisory across WalletConnect/Ledger/Trezor sub-trees.",
    "@stablelib/ed25519 (WalletConnect moderate chain): no upstream fix without regressive downgrade of web3wallet (1.16.1→1.13.0). Acknowledged 2026-07-05. Wallet key signing uses @noble/curves — unaffected. Revisit when @walletconnect/relay-auth ships a patched 1.x release."
  ],
  "overrides": {
    "serialize-javascript": "^7.0.0",
    "axios": "^1.18.0",
    "protobufjs": "^7.6.4",
    "ethers": {
      "ws": "^8.21.0"
    },
    "rpc-websockets": {
      "ws": "^8.21.0"
    },
    "elliptic": "^6.6.1",
    "ajv": "^6.15.0",
    "@ledgerhq/client-ids": {
      "uuid": "^11.1.1"
    },
    "jayson": {
      "uuid": "^11.1.1"
    }
  }
