<?xml version="1.0" encoding="utf-8"?>
<!--
  API 31+ (Android 12+) splash screen overrides.
  Uses the AndroidX SplashScreen API attributes so the system-managed
  splash window shows the Veyrnox hex mark on a near-black background
  instead of the default white window.
  postSplashScreenTheme transitions to the app's normal no-action-bar theme.
-->
<resources>
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#050608</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>
