<?xml version="1.0" encoding="utf-8"?>
<!--
  Veyrnox launcher foreground — hex mark.
  ViewBox mirrors VeyrnoxLogo.jsx (512 × 512).
  Flat teal (#4ADAC2) used for stroke; gradients are unreliable in
  adaptive-icon foreground layers across all API levels.
  Background is transparent so the ic_launcher_background color shows through.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Flat-top hexagon: teal-tinted near-black fill + teal stroke -->
    <path
        android:pathData="M169,104 L343,104 L431,256 L343,408 L169,408 L81,256 Z"
        android:fillColor="#12211F"
        android:strokeColor="#4ADAC2"
        android:strokeWidth="20"
        android:strokeLineJoin="round" />

    <!-- The "V" cutout — stroke only, no fill -->
    <path
        android:pathData="M188,188 L256,330 L324,188"
        android:fillColor="#00000000"
        android:strokeColor="#4ADAC2"
        android:strokeWidth="42"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

</vector>
