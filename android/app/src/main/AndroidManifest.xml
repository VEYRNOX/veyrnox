<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Custom scheme: veyrnox://wc?uri=<wc-uri> — a dApp/WalletConnect can
                 launch Veyrnox with no domain verification (works on an installed app).
                 singleTask (above) keeps it a single instance so appUrlOpen fires into
                 the running app. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="veyrnox" />
            </intent-filter>

            <!-- Verified App Links: https://veyrnox.com/wc?uri=... — autoVerify checks
                 https://veyrnox.com/.well-known/assetlinks.json (see public/.well-known/).
                 Only opens Veyrnox directly once verification passes AND the app is
                 installed; falls back to the browser otherwise. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="veyrnox.com" android:pathPrefix="/wc" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required for the QR-code scanner in the Send flow and for WalletConnect
         pairing (src/components/QRScanner.jsx uses navigator.mediaDevices.getUserMedia
         via Capacitor's WebView; the WebView's onPermissionRequest requires this
         manifest declaration or the runtime prompt silently fails and QR scanning
         breaks). Camera is used to scan; frames are decoded on-device by jsQR and
         never leave the device. Declared as an optional hardware feature so tablets
         or emulators without a camera can still install. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- Required for the Voice Commands feature (src/context/VoiceContext.jsx via
         @capacitor-community/speech-recognition). Read-only navigation only —
         never initiates or signs a transaction by voice. Transcription happens
         off-device on the platform speech service (Google Speech Service on
         Android). Suppressed entirely in decoy/hidden sessions (I3, fail closed). -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Required for BiometricPrompt (fingerprint / face unlock + 2FA at Send).
         USE_BIOMETRIC covers API 28+; USE_FINGERPRINT covers API 23–27. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
</manifest>
