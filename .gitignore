# Dependencies
# No trailing slash: also ignores a stray `node_modules` symlink (an absolute
# self-referential one was accidentally committed in #667 and untracked here).
node_modules

# Per-branch worktrees (see scripts/worktree.ps1 and docs/worktrees.md)
.worktrees/
# Worktrees created by the Claude Code harness (EnterWorktree) — local-only,
# never commit. Note: .claude/launch.json IS tracked, so scope to this subdir.
.claude/worktrees/

# Build output
dist/
build/

# Trezor Connect self-hosted iframe bundle — generated at build time from node_modules.
# Re-created by: node scripts/bundle-trezor-connect.mjs  (also runs as npm prebuild).
public/trezor-connect/

# Local-only test/config overrides — NEVER commit (CI uses a full checkout).
# e.g. the worktree vitest shim that extends vitest.config.js with a server.fs.allow
# widening so the parent repo's node_modules resolves under Vite's /@fs guard.
# Structurally prevented from staging per build brief §10 (a stray fs.allow
# widening must not escape into a squash-merge).
*.local.mjs
vitest.worktree.local.mjs

# Secrets / environment — NEVER commit these
.env
.env.*
*.key
*.pem
*.keystore
# Signing keystores. Globs, NOT exact filenames — a named-file rule
# (e.g. `veyrnox-release.jks`) silently misses any other name, which is how
# veyrnox-upload-new.jks sat unignored. Note `*.keystore` does NOT match `.jks`.
*.jks
*.p12
*.jceks
secrets.json
# ...except the committed template of var NAMES (no values). The negation must
# come AFTER the .env.* rule above or git keeps ignoring it.
!.env.example

# Logs
*.log
npm-debug.log*

# Audit harness run artifacts — generated, timestamped output of
# scripts/audit/eth-wallet-audit.mjs. Regenerated on demand; never commit.
docs/audit-runs/

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local wallet artifacts (safety: never commit any seed/key material)
*.mnemonic
*.seed

# Claude Code tool artifacts — local only
.claire/
.clone/
.gstack/
.claude/agents/browser/
.claude/agents/consensus/
.claude/agents/core/
.claude/agents/sparc/
.claude/agents/swarm/
.claude/agents/testing/
.claude/commands/agents/
.claude/commands/analysis/
