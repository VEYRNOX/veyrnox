.claude/skills/v3-*/
.claude/skills/verification-quality/
.github/skills/
CLAUDE.md.bak
test-results/
audit.json
convert-og.html
wallet-backup*

# ruflo / ECC memory tooling — local-only state dropped into the worktree by the
# MCP memory/swarm tools (memory_store, swarm_init, etc.). Never commit.
.swarm/
ruvector.db
*.ruvector.db
veyrnox-release.jks
keystore.jks
dist-release/

# Playwright
test-results/
playwright-report/
.auth/
playwright/.auth/
.claude/scheduled_tasks.lock
.impeccable/
.github/hooks/impeccable.json

# Local Android signing credentials (NEVER commit)
keystore.properties
android/keystore.properties
