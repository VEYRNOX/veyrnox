<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>Veyrnox</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<!-- Export compliance. Declares that the app uses only encryption that is
	     exempt from US export documentation requirements: standard, published
	     algorithms (AES-256-GCM, TLS, secp256k1/ed25519, Argon2id) used for
	     authentication and for protecting the user's own data on their own
	     device. Nothing proprietary, and no cryptanalytic functionality.

	     Setting this suppresses the per-build encryption questionnaire in App
	     Store Connect. Without it, every upload is asked again — and answering
	     "available in France = Yes" demands an ANSSI declaration document, which
	     is what left build 1.0 (2) stuck at "Missing Compliance" (a draft
	     worksheet uploaded 2026-07-14 sat In Review with no Key Value issued).

	     This is a legal declaration, not a build flag. If the app ever adds
	     proprietary crypto, or any feature that could be read as cryptanalytic,
	     this must be revisited with counsel before the next submission. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>NSFaceIDUsageDescription</key>
	<string>Authenticate with Face ID to unlock your wallet</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Veyrnox uses speech recognition so you can navigate the app hands-free. Your speech is sent to Apple's speech service for transcription; it is never used to unlock your wallet or access keys.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Veyrnox needs the microphone only while Voice Commands are switched on, to hear navigation commands.</string>
	<!-- Custom URL scheme so dApps / WalletConnect can launch Veyrnox via
	     veyrnox://wc?uri=<wc-uri>. Works on an installed app with no hosting or
	     domain verification (unlike the universal link below). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.veyrnox.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>veyrnox</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
