{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets|coins|trezor-connect|veyrnox-icon.svg).*)", "destination": "/index.html" }
  ]
}
