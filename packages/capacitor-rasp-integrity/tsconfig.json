{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "target": "ES2017",
    "module": "ES2015",
    "moduleResolution": "node",
    "declaration": true,
    "outDir": "dist/esm",
    "inlineSources": true,
    "inlineSourceMap": true
  },
  "include": ["src"]
}
