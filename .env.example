# Veyrnox — environment variable template (NAMES ONLY, no real values).
# Copy to `.env.local` (git-ignored) and fill in.
#
# Veyrnox's WALLET core is on-device: no server holds keys, seeds, or balances
# (see CLAUDE.md I1–I5). The ONE optional backend touchpoint is an anonymous
# referral counter (Supabase) — its URL + anon key are CLIENT-EXPOSED public
# values (not secrets), and the table stores only { code, count } (no identity,
# addresses, or holdings). Leave the Supabase vars blank to disable referrals
# entirely (the client no-ops — see src/api/referralApi.js).
#
# The only genuinely sensitive values here are the *testnet* signing inputs at
# the bottom, used solely by the Node verification scripts in scripts/.

# --- App build / runtime flags (Vite, client-exposed; not secret) ---
# Demo tour with fake seeded balances. Also triggers on ?demo=1 or a persisted
# veyrnox-demo=1 in localStorage. Leave unset for a real wallet.
VITE_DEMO_MODE=

# Release build hardening toggle (1 in release builds).
VITE_RELEASE=

# Banner label shown in non-prod builds, e.g. SIT or UAT.
VITE_ENV_LABEL=

# Environment name consumed by build scripts, e.g. production | sit | uat.
VITE_ENV=

# Vite base public path (only set if hosting under a sub-path).
VITE_BASE=

# DEV-ONLY: flip the send gate so receive_only assets can be sent for testnet
# verification. Dead-code-eliminated from production builds. Set in .env.local,
# never inline (inline shell vars fail on Windows/PowerShell). See CLAUDE.md.
VITE_DEV_UNGATE_SEND=

# --- dApp Connector (WalletConnect v2 / Reown) — OPTIONAL; client-exposed, NOT secret ---
# A free project ID from dashboard.reown.com (formerly cloud.walletconnect.com).
# It is a PUBLIC client identifier (it ships in the bundle), NOT a key/secret.
# Required to enable the dApp Connector — absent it, the page honest-disables and
# shows a "Project ID required" setup card (src/pages/WalletConnect.jsx;
# src/wallet-core/evm/walletconnect/session.js). NOTE: this value is baked in at
# `vite build` time, so MOBILE builds need it set BEFORE `npm run mobile:build` /
# `npm run android:run` — there is no runtime .env on the device.
VITE_WALLETCONNECT_PROJECT_ID=

# --- Referral tracker backend (OPTIONAL, Supabase; client-exposed, NOT secret) ---
# The lone backend touchpoint. Both are public client values — the anon key is
# designed to ship in the bundle; row-level security guards the table (see
# supabase/referrals.sql). Leave BOTH blank to disable referrals: registerCode/
# fetchStatus become no-ops and redeemCode returns 503 (src/api/referralApi.js).
# The table stores only { code, count } — no identity, addresses, or holdings.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Testnet verification scripts ONLY (scripts/*.mjs) — SENSITIVE ---
# These are read by Node at runtime (process.env). Use a THROWAWAY testnet key
# that has only testnet funds. NEVER put a mainnet key or your real wallet seed
# here, and never commit a filled-in copy (.env.local is git-ignored).
SEPOLIA_RPC_URL=
# Provide EITHER a mnemonic OR a raw private key (testnet, disposable):
MNEMONIC=
PRIVATE_KEY=
# Optional send params for the proof scripts:
TO_ADDRESS=
AMOUNT_ETH=
